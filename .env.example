# === 飞书应用凭证 ===
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# === 飞书事件回调 ===
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

# === 飞书多维表格 ===
FEISHU_BITABLE_APP_TOKEN=
# 以下 table_id 可从多维表格 URL 中获取：https://bytedance.feishu.cn/base/<app_token>?table=<table_id>
FEISHU_TABLE_RAW_INPUTS=
FEISHU_TABLE_CHORE_RECORDS=
FEISHU_TABLE_SETTLEMENT_RECORDS=

# === 成员映射 ===
# JSON 格式：{"ou_xxx":"A","ou_yyy":"B"}
# sender_id → 成员名，未映射的显示为 ou_xx...xx
MEMBER_MAP_JSON=

# === LLM ===
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# === 双周结算配置 ===
# 启用结算（true/false）
SETTLEMENT_ENABLED=true
# 锚点日期：第一个双周周期的起始日期（如 2026-07-27）
SETTLEMENT_ANCHOR_DATE_STR=2026-07-27
# 每次结算推送的时间
SETTLEMENT_TIME=09:00
# 结算周期天数（默认 14 天）
SETTLEMENT_INTERVAL_DAYS=14
# 结算信息推送的目标群聊 chat_id
SETTLEMENT_CHAT_ID=oc_xxxxxxxxx

# === 运行模式 ===
# BOT_RUN_MODE=ws    — 飞书 WebSocket 长连接（默认，用于生产）
# BOT_RUN_MODE=http  — FastAPI HTTP 服务（用于健康检查或 HTTP 回调）
BOT_RUN_MODE=ws

# === 时区 ===
TIMEZONE=Asia/Shanghai
